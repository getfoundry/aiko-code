{
  "name": "aiko-code-vscode",
  "displayName": "aiko-code",
  "description": "Practical VS Code companion for Aiko Code with project-aware launch behavior and a real Control Center.",
  "version": "0.2.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:aiko-code.start",
    "onCommand:aiko-code.startInWorkspaceRoot",
    "onCommand:aiko-code.openDocs",
    "onCommand:aiko-code.openSetupDocs",
    "onCommand:aiko-code.openWorkspaceProfile",
    "onCommand:aiko-code.openControlCenter",
    "onCommand:aiko-code.newChat",
    "onCommand:aiko-code.openChat",
    "onCommand:aiko-code.resumeSession",
    "onCommand:aiko-code.abortChat",
    "onView:aiko-code.controlCenter",
    "onView:aiko-code.chat"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "src/chat/**",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aiko-code.start",
        "title": "aiko-code: Launch in Terminal",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.startInWorkspaceRoot",
        "title": "aiko-code: Launch in Workspace Root",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.openDocs",
        "title": "aiko-code: Open Repository",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.openSetupDocs",
        "title": "aiko-code: Open Setup Guide",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.openWorkspaceProfile",
        "title": "aiko-code: Open Workspace Profile",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.openControlCenter",
        "title": "aiko-code: Open Control Center",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.newChat",
        "title": "aiko-code: New Chat",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.openChat",
        "title": "aiko-code: Open Chat Panel",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.resumeSession",
        "title": "aiko-code: Resume Session",
        "category": "aiko-code"
      },
      {
        "command": "aiko-code.abortChat",
        "title": "aiko-code: Abort Generation",
        "category": "aiko-code"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiko-code",
          "title": "aiko-code",
          "icon": "media/aiko-code.svg"
        }
      ]
    },
    "views": {
      "aiko-code": [
        {
          "id": "aiko-code.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "aiko-code.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "aiko-code.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "aiko-code",
      "properties": {
        "aiko-code.launchCommand": {
          "type": "string",
          "default": "aiko-code",
          "description": "Command run in the integrated terminal when launching aiko-code."
        },
        "aiko-code.terminalName": {
          "type": "string",
          "default": "aiko-code",
          "description": "Integrated terminal tab name for Aiko Code sessions."
        },
        "aiko-code.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set aiko_CODE_USE_OPENAI=1 in launched Aiko Code terminals."
        },
        "aiko-code.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"],
          "enumDescriptions": [
            "Prompt for permission on each tool use (requires manual approval)",
            "Auto-approve file edits, prompt for other operations (recommended)",
            "Auto-approve all operations without prompting",
            "Read-only mode — no file modifications allowed"
          ],
          "description": "Permission mode for chat sessions. Controls which tool operations are auto-approved."
        }
      }
    },
    "themes": [
      {
        "label": "Aiko Code Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/aiko-code-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node scripts/lint.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "aiko-code",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/getfoundry/aiko-code"
  },
  "license": "MIT"
}
